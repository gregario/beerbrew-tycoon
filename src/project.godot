; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="BeerBrew Tycoon"
config/description="A brewery management sim with roguelite meta-progression."
config/version="0.1.0"
run/main_scene="res://scenes/Game.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://autoloads/GameState.gd"
QualityCalculator="*res://autoloads/QualityCalculator.gd"
MarketManager="*res://autoloads/MarketManager.gd"
ToastManager="*res://autoloads/ToastManager.gd"
BrewingScience="*res://autoloads/BrewingScience.gd"
TasteSystem="*res://autoloads/TasteSystem.gd"
FailureSystem="*res://autoloads/FailureSystem.gd"
EquipmentManager="*res://autoloads/EquipmentManager.gd"
ResearchManager="*res://autoloads/ResearchManager.gd"
StaffManager="*res://autoloads/StaffManager.gd"
BreweryExpansion="*res://autoloads/BreweryExpansion.gd"
ContractManager="*res://autoloads/ContractManager.gd"
CompetitionManager="*res://autoloads/CompetitionManager.gd"
PathManager="*res://autoloads/PathManager.gd"
SpecialtyBeerManager="*res://autoloads/SpecialtyBeerManager.gd"
MetaProgressionManager="*res://autoloads/MetaProgressionManager.gd"
RunModifierManager="*res://autoloads/RunModifierManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[rendering]

textures/canvas_textures/default_texture_filter=0
